# ===================
# Backend Configuration
# ===================

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=vandyguessr

# Redis
REDIS_URL=redis://localhost:6379

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your-azure-client-id

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# Upload
UPLOAD_SECRET_CODE=your-uuid-here
UPLOAD_MAX_BYTES=52428800
UPLOAD_MAX_DIMENSION=17000
UPLOAD_MAX_PIXELS=70000000
UPLOAD_MAX_PROJECTED_FULL_WIDTH=17000
UPLOAD_QUEUE_KEY=images:submission:queue
UPLOAD_QUEUE_MAX_ATTEMPTS=3
UPLOAD_TEMP_PREFIX=images/uploads-temp

# Image Processing
PANORAMA_BASE_MAX_WIDTH=2048
PANORAMA_MAX_SOURCE_WIDTH=16384
PANORAMA_BASE_QUALITY=60
PANORAMA_TILE_QUALITY=80
IMAGE_ORIGINAL_JPEG_QUALITY=84
IMAGE_ORIGINAL_MIN_SAVINGS_RATIO=0.08

# Comma-separated Vanderbilt emails that may list/approve/reject crowd submissions (case-insensitive)
REVIEWER_EMAIL_ALLOWLIST=reviewer1@vanderbilt.edu,reviewer2@vanderbilt.edu

# Feature Flags
FEATURE_MULTIPLAYER=false

# DigitalOcean Spaces (S3-compatible)
SPACES_REGION=nyc3
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_BUCKET=your-bucket
SPACES_ACCESS_KEY=your-access-key
SPACES_SECRET_KEY=your-secret-key
